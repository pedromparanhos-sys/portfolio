{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/containers/**",
              "components/core/**",
              "components/site/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Soufflet Vert Hybrid 106R|Geist Mono|Geist))/i]",
        "message": "Font not provided by the design system. Available: Soufflet Vert Hybrid 106R, Geist Mono, Geist."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|iconSide|pressed|center|disabled|href|onClick|children|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, icon, iconSide, pressed, center, disabled, href, onClick, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|theme|action)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'theme' | 'action'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconSide'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Button> iconSide must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:isDark|onTheme|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: isDark, onTheme."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|mono|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, src, size, mono, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoChit'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<InfoChit> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MiniCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|text|key|ref|className|style|children)$/]",
        "message": "<MiniCard> doesn't accept that prop. Declared props: value, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutlineBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|titleStyle|style|key|ref|className|style|children)$/]",
        "message": "<OutlineBox> doesn't accept that prop. Declared props: title, children, titleStyle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:ratio|chunkWidth|chunkHeight|chunkSpacing|size|disabled|dark|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: ratio, chunkWidth, chunkHeight, chunkSpacing, size, disabled, dark."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:normal|big|small)$/]",
        "message": "<ProgressBar> size must be one of 'normal' | 'big' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioSelectBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|selected|onChange|key|ref|className|style|children)$/]",
        "message": "<RadioSelectBar> doesn't accept that prop. Declared props: options, selected, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|style|key|ref|className|style|children)$/]",
        "message": "<RunBox> doesn't accept that prop. Declared props: title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShadowCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|onClick|children|style|className|key|ref|className|style|children)$/]",
        "message": "<ShadowCard> doesn't accept that prop. Declared props: href, onClick, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sort'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|selected|onChange|key|ref|className|style|children)$/]",
        "message": "<Sort> doesn't accept that prop. Declared props: options, selected, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<StatBox> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|variant|inverted|children|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: status, variant, inverted, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:active|funding|completed|paused|waitingForMembers)$/]",
        "message": "<StatusChip> status must be one of 'active' | 'funding' | 'completed' | 'paused' | 'waitingForMembers'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:minimal|bold)$/]",
        "message": "<StatusChip> variant must be one of 'minimal' | 'bold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SymbolSeparatedItems'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<SymbolSeparatedItems> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
